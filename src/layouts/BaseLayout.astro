---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import type { Lang } from '../i18n/translations';
import type { PageKey } from '../data/navigation';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  currentPage: PageKey;
}

const { title, description, lang, currentPage } = Astro.props;
const siteName = 'CiniliCafe';
const pagePath = currentPage === 'home' ? '' : currentPage;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} | {siteName}</title>
    <link rel="alternate" hreflang="tr" href={`/tr/${pagePath}`} />
    <link rel="alternate" hreflang="en" href={`/en/${pagePath}`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="flex flex-col min-h-screen bg-cream text-ink antialiased">
    <Header lang={lang} currentPage={currentPage} />
    <!--
      Spacer that matches the header's rendered height.
      The header is position:fixed so it's out of document flow.
      This div prevents page content from sitting under the header.
      min-height CSS default (nav 62px + strip ~29px) prevents content flash before JS runs.
      JS in Header.astro keeps its exact height in sync.
    -->
    <div id="header-spacer" aria-hidden="true" style={`min-height: ${currentPage === 'home' ? '143' : '91'}px`}></div>
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />

    <!-- Sticky bottom bar (Bacha-style) -->
    <div
      class="fixed bottom-0 left-0 right-0 z-40 bg-navy border-t border-caramel/20"
      style="height: 44px;"
    >
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-full flex items-center justify-between">
        <span class="text-cream/45 text-[10px] tracking-[0.15em] uppercase">
          &copy; 2026 Cinili Cafe
          <span class="hidden sm:inline">&nbsp;&mdash;&nbsp;{lang === 'tr' ? 'Tüm Hakları Saklıdır' : 'All Rights Reserved'}</span>
        </span>
        <a
          href="https://instagram.com/cinilicafe"
          target="_blank"
          rel="noopener"
          class="text-cream/45 hover:text-cream transition-colors text-[10px] tracking-[0.18em] uppercase font-medium"
        >
          @cinilicafe
        </a>
        <button
          onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
          class="text-cream/45 hover:text-cream transition-colors text-[10px] tracking-[0.15em] uppercase flex items-center gap-1.5"
          aria-label="Scroll to top"
        >
          <span class="hidden sm:inline">{lang === 'tr' ? 'Yukarı' : 'Back to top'}</span>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
          </svg>
        </button>
      </div>
    </div>
    <!-- Spacer so the page footer content isn't hidden behind the sticky bar -->
    <div style="height: 44px;" aria-hidden="true"></div>
  </body>
</html>
