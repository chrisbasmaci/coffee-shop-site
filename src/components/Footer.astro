---
import { t } from '../i18n/translations';
import type { Lang } from '../i18n/translations';
import { navigation } from '../data/navigation';
import { siteInfo } from '../data/siteInfo';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t[lang];
const nav = navigation[lang];
const footerLinks = [
  { label: nav.menu,    href: `/${lang}/menu` },
  { label: nav.shop,    href: `/${lang}/shop` },
  { label: nav.contact, href: `/${lang}/contact` },
];
---

<footer class="bg-espresso text-cream/75">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 pb-8 border-b border-cream/10">

      <!-- Brand -->
      <div>
        <p class="font-serif text-xl text-cream font-semibold mb-2">CiniliCafe</p>
        <p class="text-sm italic text-cream/50">{tr.footer.tagline}</p>
      </div>

      <!-- Pages -->
      <div>
        <p class="text-xs uppercase tracking-widest text-cream/40 mb-3">{tr.footer.pagesLabel}</p>
        <ul class="flex flex-col gap-2">
          {footerLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm text-cream/70 hover:text-cream transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Hours -->
      <div>
        <p class="text-xs uppercase tracking-widest text-cream/40 mb-3">
          {tr.contact.labels.hours}
        </p>
        <ul class="text-sm space-y-2">
          {siteInfo.openingHours[lang].map(row => (
            <li class="text-cream/70">{row}</li>
          ))}
        </ul>
      </div>
    </div>

    <p class="mt-8 text-xs text-cream/30 text-center">{tr.footer.copyright}</p>
  </div>
</footer>

