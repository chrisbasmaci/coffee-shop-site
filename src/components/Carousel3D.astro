---
export interface CarouselItem {
  id: string;
  title: string;
  description: string;
  price: string;
  badge?: string | undefined;
  image: string;
  externalUrl: string;
}

interface Props {
  carouselId: string;
  items: CarouselItem[];
  viewLabel: string;
  prevLabel?: string;
  nextLabel?: string;
}

const {
  carouselId,
  items,
  viewLabel,
  prevLabel = '←',
  nextLabel = '→',
} = Astro.props;

// Pre-calculate initial SSR styles (desktop values, currentIndex = 0)
function initialStyle(i: number, total: number): string {
  const pos = i > total / 2 ? i - total : i;
  if (pos === 0)
    return 'transform:translateX(-50%) scale(1) rotateY(0deg) translateZ(0px);opacity:1;z-index:10;';
  if (pos === 1)
    return 'transform:translateX(calc(-50% + 240px)) scale(0.82) rotateY(-25deg) translateZ(-90px);opacity:0.85;z-index:6;';
  if (pos === -1)
    return 'transform:translateX(calc(-50% - 240px)) scale(0.82) rotateY(25deg) translateZ(-90px);opacity:0.85;z-index:6;';
  if (pos === 2)
    return 'transform:translateX(calc(-50% + 430px)) scale(0.67) rotateY(-40deg) translateZ(-200px);opacity:0.4;z-index:2;';
  if (pos === -2)
    return 'transform:translateX(calc(-50% - 430px)) scale(0.67) rotateY(40deg) translateZ(-200px);opacity:0.4;z-index:2;';
  const dir = pos > 0 ? 1 : -1;
  return `transform:translateX(calc(-50% + ${dir * 600}px)) scale(0.5) rotateY(${-dir * 50}deg) translateZ(-280px);opacity:0;z-index:0;`;
}
---

<div
  class="relative w-full select-none"
  id={carouselId}
  data-carousel
  aria-roledescription="carousel"
  aria-label={items[0]?.title}
>
  <!-- Stage -->
  <div
    class="relative overflow-hidden"
    style="height: 360px; perspective: 1200px; perspective-origin: 50% 40%;"
    data-carousel-stage
  >
    {items.map((item, i) => (
      <div
        class="absolute left-1/2 top-0 w-[210px] sm:w-[250px] cursor-pointer"
        style={`${initialStyle(i, items.length)} transition: transform 0.55s cubic-bezier(0.25,0.46,0.45,0.94), opacity 0.55s ease;`}
        data-carousel-item
        data-idx={i}
        aria-hidden={i !== 0 ? 'true' : 'false'}
        role="group"
        aria-roledescription="slide"
        aria-label={item.title}
      >
        <!-- Card -->
        <div class="bg-cream rounded-2xl overflow-hidden border border-warm-border shadow-md">
          <!-- Image area -->
          <div class="relative bg-parchment overflow-hidden" style="aspect-ratio:1/1;">
            {item.badge && (
              <span class="absolute top-3 left-3 z-10 text-xs font-medium bg-caramel text-cream px-2.5 py-1 rounded-full">
                {item.badge}
              </span>
            )}
            <img
              src={item.image}
              alt={item.title}
              class="w-full h-full object-cover"
              loading="lazy"
              onerror="this.style.display='none'"
            />
            <!-- Fallback placeholder shown when image missing -->
            <div class="absolute inset-0 flex items-center justify-center pointer-events-none" aria-hidden="true">
              <span class="font-serif text-5xl text-caramel/15 leading-none">ç</span>
            </div>
          </div>

          <!-- Content -->
          <div class="p-4">
            <h3 class="font-serif text-espresso font-semibold text-sm sm:text-base leading-snug mb-1 line-clamp-1">
              {item.title}
            </h3>
            <p class="text-caramel font-medium text-xs sm:text-sm mb-2">{item.price}</p>
            <p class="text-sand text-xs leading-relaxed mb-4 line-clamp-2">{item.description}</p>
            <a
              href={item.externalUrl}
              class="block text-center text-xs font-medium border border-espresso/25 text-espresso px-3 py-2 rounded-lg hover:bg-espresso hover:text-cream transition-colors"
              tabindex={i === 0 ? '0' : '-1'}
            >
              {viewLabel}
            </a>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Prev button -->
  <button
    class="absolute left-2 sm:left-6 top-[160px] z-20 w-10 h-10 rounded-full bg-cream border border-warm-border shadow flex items-center justify-center text-espresso hover:bg-espresso hover:text-cream transition-colors"
    data-carousel-prev
    aria-label={prevLabel}
    type="button"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
  </button>

  <!-- Next button -->
  <button
    class="absolute right-2 sm:right-6 top-[160px] z-20 w-10 h-10 rounded-full bg-cream border border-warm-border shadow flex items-center justify-center text-espresso hover:bg-espresso hover:text-cream transition-colors"
    data-carousel-next
    aria-label={nextLabel}
    type="button"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </button>

  <!-- Dots -->
  <div class="flex justify-center gap-2 pt-4 pb-2" role="tablist" aria-label="Carousel navigation">
    {items.map((item, i) => (
      <button
        class="w-2 h-2 rounded-full transition-all duration-300"
        style={i === 0 ? 'background-color: #B8722A; width: 1.5rem;' : 'background-color: #E0D4C4;'}
        data-carousel-dot
        data-goto={i}
        type="button"
        role="tab"
        aria-label={item.title}
        aria-selected={i === 0 ? 'true' : 'false'}
      />
    ))}
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach(carousel => {
    let current = 0;
    const items = Array.from(carousel.querySelectorAll<HTMLElement>('[data-carousel-item]'));
    const dots  = Array.from(carousel.querySelectorAll<HTMLElement>('[data-carousel-dot]'));
    const total = items.length;

    function offsets() {
      const w = window.innerWidth;
      // [s1, s2, sc1, sc2, ry, tz1, tz2]
      if (w < 640)  return [155, 290, 0.78, 0.62, 25, -70, -160] as const;
      if (w < 1024) return [210, 380, 0.80, 0.65, 25, -80, -185] as const;
      return              [240, 430, 0.82, 0.67, 25, -90, -200] as const;
    }

    function update() {
      const [s1, s2, sc1, sc2, ry, tz1, tz2] = offsets();
      items.forEach((el, i) => {
        // Wrap-aware position relative to current
        let pos = i - current;
        if (pos > total / 2)  pos -= total;
        if (pos < -total / 2) pos += total;

        let transform: string, opacity: string, zIndex: string;

        if (pos === 0) {
          transform = `translateX(-50%) scale(1) rotateY(0deg) translateZ(0px)`;
          opacity = '1'; zIndex = '10';
        } else if (pos === 1) {
          transform = `translateX(calc(-50% + ${s1}px)) scale(${sc1}) rotateY(-${ry}deg) translateZ(${tz1}px)`;
          opacity = '0.85'; zIndex = '6';
        } else if (pos === -1) {
          transform = `translateX(calc(-50% - ${s1}px)) scale(${sc1}) rotateY(${ry}deg) translateZ(${tz1}px)`;
          opacity = '0.85'; zIndex = '6';
        } else if (pos === 2) {
          transform = `translateX(calc(-50% + ${s2}px)) scale(${sc2}) rotateY(-${ry + 15}deg) translateZ(${tz2}px)`;
          opacity = '0.35'; zIndex = '2';
        } else if (pos === -2) {
          transform = `translateX(calc(-50% - ${s2}px)) scale(${sc2}) rotateY(${ry + 15}deg) translateZ(${tz2}px)`;
          opacity = '0.35'; zIndex = '2';
        } else {
          const dir = pos > 0 ? 1 : -1;
          transform = `translateX(calc(-50% + ${dir * (s2 + 160)}px)) scale(0.5) rotateY(${-dir * 50}deg) translateZ(-280px)`;
          opacity = '0'; zIndex = '0';
        }

        el.style.transform = transform;
        el.style.opacity   = opacity;
        el.style.zIndex    = zIndex;
        el.setAttribute('aria-hidden', pos !== 0 ? 'true' : 'false');

        // Make only the center card's link focusable
        const link = el.querySelector<HTMLAnchorElement>('a');
        if (link) link.tabIndex = pos === 0 ? 0 : -1;
      });

      dots.forEach((dot, i) => {
        const active = i === current;
        dot.style.backgroundColor = active ? '#B8722A' : '#E0D4C4';
        dot.style.width = active ? '1.5rem' : '0.5rem';
        dot.setAttribute('aria-selected', active ? 'true' : 'false');
      });
    }

    // Click side items to jump to them
    items.forEach((el, i) => {
      el.addEventListener('click', () => {
        let pos = i - current;
        if (pos > total / 2)  pos -= total;
        if (pos < -total / 2) pos += total;
        if (pos !== 0) { current = i; update(); }
      });
    });

    carousel.querySelector('[data-carousel-prev]')?.addEventListener('click', () => {
      current = (current - 1 + total) % total;
      update();
    });

    carousel.querySelector('[data-carousel-next]')?.addEventListener('click', () => {
      current = (current + 1) % total;
      update();
    });

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => { current = i; update(); });
    });

    // Touch / swipe
    let touchX = 0;
    carousel.addEventListener('touchstart', e => { touchX = (e as TouchEvent).touches[0].clientX; }, { passive: true });
    carousel.addEventListener('touchend', e => {
      const diff = touchX - (e as TouchEvent).changedTouches[0].clientX;
      if (Math.abs(diff) > 40) {
        current = diff > 0 ? (current + 1) % total : (current - 1 + total) % total;
        update();
      }
    }, { passive: true });

    // Keyboard
    carousel.addEventListener('keydown', e => {
      if ((e as KeyboardEvent).key === 'ArrowLeft')  { current = (current - 1 + total) % total; update(); }
      if ((e as KeyboardEvent).key === 'ArrowRight') { current = (current + 1) % total; update(); }
    });

    // Recalculate on resize for breakpoint changes
    window.addEventListener('resize', update, { passive: true });

    // First render (corrects mobile offsets from SSR desktop values)
    update();
  });
</script>
