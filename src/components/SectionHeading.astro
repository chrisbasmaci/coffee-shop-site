---
interface Props {
  label?: string;
  heading: string;
  subtitle?: string;
  centered?: boolean;
}

const { label, heading, subtitle, centered = false } = Astro.props;
---

<div class:list={['mb-10 sm:mb-12', centered && 'text-center']}>
  {label && (
    <p class="text-caramel text-xs font-medium tracking-[0.2em] uppercase mb-3">
      {label}
    </p>
  )}
  <h2 class="font-serif text-3xl sm:text-4xl text-espresso font-semibold leading-snug mb-3">
    {heading}
  </h2>
  {subtitle && (
    <p class:list={['text-sand text-sm sm:text-base leading-relaxed', centered && 'max-w-xl mx-auto']}>
      {subtitle}
    </p>
  )}
</div>
