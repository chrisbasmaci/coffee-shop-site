---
interface Props {
  label: string;
  value: string;
  href?: string;
  multiline?: boolean;
}

const { label, value, href, multiline = false } = Astro.props;
---

<div>
  <p class="text-xs font-medium tracking-[0.2em] uppercase text-caramel mb-1.5">
    {label}
  </p>
  {href ? (
    <a
      href={href}
      class:list={['text-ink hover:text-caramel transition-colors text-base', multiline && 'break-all']}
    >
      {value}
    </a>
  ) : (
    <p class="text-ink text-base">{value}</p>
  )}
</div>
