---
import LanguageToggle from './LanguageToggle.astro';
import { navigation } from '../data/navigation';
import type { Lang } from '../i18n/translations';
import type { PageKey } from '../data/navigation';

interface Props {
  lang: Lang;
  currentPage: PageKey;
}

const { lang, currentPage } = Astro.props;
const nav = navigation[lang];

const links: { key: PageKey; label: string; href: string }[] = [
  { key: 'home',    label: nav.home,    href: `/${lang}/` },
  { key: 'menu',    label: nav.menu,    href: `/${lang}/menu` },
  { key: 'shop',    label: nav.shop,    href: `/${lang}/shop` },
  { key: 'contact', label: nav.contact, href: `/${lang}/contact` },
];

const announcements = {
  tr: [
    'Menümüzü ve mağazamızı keşfedin.',
    'Büyük Çarşı\'da sizi bekliyoruz.',
    'El yapımı çinili ürünlerimizi görün.',
  ],
  en: [
    'Discover our menu and shop.',
    'Visit us at the Grand Bazaar.',
    'Explore our handcrafted tile products.',
  ],
};
---

<div id="site-header" class="fixed top-0 left-0 right-0 z-50">

  <!-- MAIN NAV BAR — flexbox so explicit height on logo link never expands the row -->
  <nav
    class="bg-navy"
    style="position: relative; z-index: 20; height: 62px; overflow: visible;"
    aria-label={lang === 'tr' ? 'Ana menü' : 'Main navigation'}
  >
    <div class="w-full px-4 sm:px-6 lg:px-8 flex items-center h-full">

      <!-- Logo: explicit height:62px keeps flex row at 62px; the img overflows
           below on desktop thanks to overflow:visible on the nav. -->
      <a
        id="header-logo-link"
        href={`/${lang}/`}
        class="flex-none flex items-center md:items-start mr-4 overflow-visible"
        style="height: 62px;"
        aria-label="CiniliCafe – Ana Sayfa"
      >
        <img
          id="header-logo-img"
          src="/images/logo.png"
          alt="Çinili"
          class="h-9 md:h-28 w-auto object-contain drop-shadow-lg hover:opacity-90 transition-opacity"
          loading="eager"
        />
      </a>

      <!-- Desktop links: clamp margin keeps links close to logo, never drifting far right -->
      <ul
        class="hidden md:flex items-center gap-6 lg:gap-10 ml-[clamp(2rem,_7vw,_6rem)]"
        role="list"
      >
        {links.map(link => (
          <li>
            <a
              href={link.href}
              class:list={[
                'text-[18px] tracking-[0.2em] uppercase font-medium transition-colors duration-200',
                link.key === currentPage
                  ? 'text-caramel'
                  : 'text-cream/65 hover:text-cream',
              ]}
              aria-current={link.key === currentPage ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Toggle: flex-none ml-auto — sits at right edge on all viewports -->
      <div class="flex-none ml-auto flex items-center gap-3">
        <div class="text-[11px] tracking-[0.15em] uppercase font-medium">
          <LanguageToggle lang={lang} currentPage={currentPage} />
        </div>
        <button
          id="nav-toggle"
          class="md:hidden p-1.5 text-cream/70 hover:text-cream transition-colors rounded"
          aria-label={lang === 'tr' ? 'Menüyü aç' : 'Open menu'}
          aria-expanded="false"
          aria-controls="mobile-nav"
        >
          <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- DECORATIVE STRIP — geometric tile diamonds, logo overlaps from above -->
  <div
    class="bg-[#0d1220] border-y border-caramel/30 py-1.5 overflow-hidden"
    style="position: relative; z-index: 10;"
    aria-hidden="true"
  >
    <span class="flex items-center justify-center gap-3.5 text-caramel/55 text-[10px] select-none whitespace-nowrap">
      {Array(120).fill(null).map(() => (
        <span>◆</span>
      ))}
    </span>
  </div>

  <!-- ROTATING ANNOUNCEMENT BAR — collapses on scroll -->
  <div id="announcement-bar" class="bg-black" role="status" aria-live="polite">
    <p
      id="announcement-text"
      class="text-center text-[11px] tracking-[0.22em] uppercase text-white font-medium px-4 transition-opacity duration-500"
    >
      {announcements[lang][0]}
    </p>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-nav" class="hidden md:hidden bg-navy border-t border-caramel/20" style="position: relative; z-index: 30;">
    <ul class="max-w-6xl mx-auto px-4 py-1 flex flex-col" role="list">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              'block py-3 text-xs tracking-[0.15em] uppercase font-medium border-b border-caramel/10 last:border-0 transition-colors',
              link.key === currentPage ? 'text-caramel' : 'text-cream/60 hover:text-cream',
            ]}
            aria-current={link.key === currentPage ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>

</div><!-- #site-header -->

<style>
  #header-logo-img {
    transition: height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  /* On desktop, logo protrudes below nav into the strip */
  @media (min-width: 768px) {
    #header-logo-link {
      padding-top: 0.25rem; /* nudge down ~20% of nav */
    }
  }
  #announcement-bar {
    max-height: 52px;
    overflow: hidden;
    transition: max-height 0.4s ease, padding-top 0.3s ease, padding-bottom 0.3s ease;
    padding-top: 0.625rem;
    padding-bottom: 0.625rem;
  }
</style>

<script define:vars={{ announcements, lang }}>
  // ── Spacer sync ──────────────────────────────────────────────────────────
  const header = document.getElementById('site-header');
  const spacer = document.getElementById('header-spacer');

  function syncSpacer() {
    if (spacer && header) spacer.style.height = header.offsetHeight + 'px';
  }
  header?.addEventListener('transitionend', syncSpacer);
  const ro = new ResizeObserver(syncSpacer);
  if (header) ro.observe(header);
  syncSpacer();

  // ── Logo collapse + announcement bar hide on scroll ──────────────────────────
  const logoLink = document.getElementById('header-logo-link');
  const logoImg  = document.getElementById('header-logo-img');
  const announcementBar = document.getElementById('announcement-bar');
  const THRESHOLD = 40;
  let scrolled = false;

  function collapseHeader() {
    if (logoImg && window.innerWidth >= 768)  logoImg.style.height = '3rem'; // desktop only — mobile logo is already small
    if (announcementBar) {
      announcementBar.style.maxHeight = '0';
      announcementBar.style.paddingTop = '0';
      announcementBar.style.paddingBottom = '0';
    }
  }

  function restoreHeader() {
    if (logoImg)  logoImg.style.height = '';  // CSS class takes over: h-9 mobile, h-28 md+
    if (announcementBar) {
      announcementBar.style.maxHeight = '';
      announcementBar.style.paddingTop = '';
      announcementBar.style.paddingBottom = '';
    }
  }

  function onScroll() {
    const y = window.scrollY;
    if (!scrolled && y > THRESHOLD)  { scrolled = true;  collapseHeader(); syncSpacer(); }
    else if (scrolled && y <= THRESHOLD) { scrolled = false; restoreHeader();  syncSpacer(); }
  }

  if (window.scrollY > THRESHOLD) { scrolled = true; collapseHeader(); }
  window.addEventListener('scroll', onScroll, { passive: true });

  // ── Rotating announcement text ───────────────────────────────────────────
  const msgs = announcements[lang];
  let idx = 0;
  const el = document.getElementById('announcement-text');
  if (el && msgs.length > 1) {
    setInterval(() => {
      el.style.opacity = '0';
      setTimeout(() => {
        idx = (idx + 1) % msgs.length;
        el.textContent = msgs[idx];
        el.style.opacity = '1';
      }, 500);
    }, 4000);
  }

  // ── Mobile menu toggle ───────────────────────────────────────────────────
  const toggle    = document.getElementById('nav-toggle');
  const menu      = document.getElementById('mobile-nav');
  const iconOpen  = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
    syncSpacer();
  });
</script>

