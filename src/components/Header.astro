---
import LanguageToggle from './LanguageToggle.astro';
import { navigation } from '../data/navigation';
import type { Lang } from '../i18n/translations';
import type { PageKey } from '../data/navigation';

interface Props {
  lang: Lang;
  currentPage: PageKey;
}

const { lang, currentPage } = Astro.props;
const nav = navigation[lang];

const links: { key: PageKey; label: string; href: string }[] = [
  { key: 'home',    label: nav.home,    href: `/${lang}/` },
  { key: 'menu',    label: nav.menu,    href: `/${lang}/menu` },
  { key: 'shop',    label: nav.shop,    href: `/${lang}/shop` },
  { key: 'contact', label: nav.contact, href: `/${lang}/contact` },
];

const announcement = lang === 'tr'
  ? 'Menülerimizi ve güncel ürünlerimizi keşfedin.'
  : 'Discover our menus and current shop items.';
---

<!--
  Two-state sticky header.
  State 1 (top): plaque logo block above the nav bar is visible.
  State 2 (scrolled, class "is-scrolled" on #site-header):
    plaque collapses, inline logo appears in the nav bar.
-->
<div id="site-header" class="sticky top-0 z-50">

  <!-- ① PLAQUE / HERO LOGO BLOCK — collapses on scroll -->
  <div
    id="header-plaque"
    class="bg-espresso overflow-hidden transition-all duration-500 ease-in-out"
    style="max-height: 120px;"
    aria-hidden="false"
  >
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-center py-4">
      <a
        href={`/${lang}/`}
        class="group"
        aria-label="CiniliCafe – Ana Sayfa"
        tabindex="0"
      >
        <img
          src="/images/logo.png"
          alt="Çinili"
          class="h-14 sm:h-16 w-auto object-contain drop-shadow-md
                 group-hover:opacity-90 transition-opacity duration-300"
          loading="eager"
        />
      </a>
    </div>
  </div>

  <!-- ② MAIN NAV BAR — always visible, dark -->
  <nav
    class="bg-espresso border-t border-caramel/15"
    aria-label={lang === 'tr' ? 'Ana menü' : 'Main navigation'}
  >
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-12 sm:h-14">

      <!-- Inline logo — hidden at top, fades in on scroll -->
      <a
        id="nav-inline-logo"
        href={`/${lang}/`}
        class="opacity-0 transition-all duration-500 pointer-events-none shrink-0"
        aria-hidden="true"
        tabindex="-1"
      >
        <img
          src="/images/logo.png"
          alt="Çinili"
          class="h-7 w-auto object-contain"
          loading="eager"
        />
      </a>

      <!-- Desktop links — centred -->
      <ul
        class="hidden md:flex items-center gap-6 lg:gap-9 mx-auto"
        role="list"
        id="desktop-nav-links"
      >
        {links.map(link => (
          <li>
            <a
              href={link.href}
              class:list={[
                'text-xs tracking-[0.15em] uppercase font-medium transition-colors duration-200',
                link.key === currentPage
                  ? 'text-caramel'
                  : 'text-cream/60 hover:text-cream',
              ]}
              aria-current={link.key === currentPage ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Right: language toggle + hamburger -->
      <div class="flex items-center gap-3">
        <!-- Language toggle styled for dark background -->
        <div class="text-xs tracking-[0.12em] uppercase font-medium">
          <LanguageToggle lang={lang} currentPage={currentPage} />
        </div>

        <button
          id="nav-toggle"
          class="md:hidden p-1.5 text-cream/70 hover:text-cream transition-colors rounded"
          aria-label={lang === 'tr' ? 'Menüyü aç' : 'Open menu'}
          aria-expanded="false"
          aria-controls="mobile-nav"
        >
          <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- ③ DECORATIVE STRIP — geometric tile-inspired border -->
  <div
    id="header-strip"
    class="overflow-hidden transition-all duration-500 ease-in-out"
    style="max-height: 28px;"
    aria-hidden="true"
  >
    <div class="bg-caramel/10 border-y border-caramel/20 py-1.5 flex items-center justify-center gap-0 overflow-hidden">
      <!-- Repeating geometric tile motif -->
      <span class="flex items-center gap-3 text-caramel/40 text-[9px] tracking-[0.4em] uppercase font-sans select-none whitespace-nowrap">
        {Array(18).fill(null).map(() => (
          <span aria-hidden="true">◆</span>
        ))}
      </span>
    </div>
  </div>

  <!-- ④ ANNOUNCEMENT BAR — collapses on scroll -->
  <div
    id="header-announcement"
    class="bg-ink overflow-hidden transition-all duration-500 ease-in-out"
    style="max-height: 36px;"
  >
    <p class="text-center text-[10px] sm:text-xs tracking-[0.18em] uppercase text-cream/50 font-sans py-2.5 px-4">
      {announcement}
    </p>
  </div>

  <!-- Mobile menu — sits outside the scroll-affected blocks -->
  <div id="mobile-nav" class="hidden md:hidden bg-espresso border-t border-caramel/20">
    <ul class="max-w-6xl mx-auto px-4 py-1 flex flex-col" role="list">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              'block py-3 text-xs tracking-[0.15em] uppercase font-medium border-b border-caramel/10 last:border-0 transition-colors',
              link.key === currentPage ? 'text-caramel' : 'text-cream/60 hover:text-cream',
            ]}
            aria-current={link.key === currentPage ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>

</div><!-- #site-header -->

<script>
  // ── Two-state scroll behaviour ─────────────────────────────────────────────
  const header       = document.getElementById('site-header')!;
  const plaque       = document.getElementById('header-plaque')!;
  const strip        = document.getElementById('header-strip')!;
  const announcement = document.getElementById('header-announcement')!;
  const inlineLogo   = document.getElementById('nav-inline-logo') as HTMLAnchorElement;

  let scrolled = false;

  function applyState(isScrolled: boolean) {
    if (isScrolled === scrolled) return;
    scrolled = isScrolled;

    if (isScrolled) {
      // Collapse decorative blocks
      plaque.style.maxHeight       = '0px';
      plaque.style.paddingTop      = '0px';
      plaque.style.paddingBottom   = '0px';
      strip.style.maxHeight        = '0px';
      announcement.style.maxHeight = '0px';
      // Show inline logo
      inlineLogo.style.opacity       = '1';
      inlineLogo.style.pointerEvents = 'auto';
      inlineLogo.removeAttribute('aria-hidden');
      inlineLogo.tabIndex = 0;
      // Add shadow to nav bar
      header.style.boxShadow = '0 2px 20px rgba(0,0,0,0.35)';
    } else {
      // Restore decorative blocks
      plaque.style.maxHeight       = '120px';
      plaque.style.paddingTop      = '';
      plaque.style.paddingBottom   = '';
      strip.style.maxHeight        = '28px';
      announcement.style.maxHeight = '36px';
      // Hide inline logo
      inlineLogo.style.opacity       = '0';
      inlineLogo.style.pointerEvents = 'none';
      inlineLogo.setAttribute('aria-hidden', 'true');
      inlineLogo.tabIndex = -1;
      header.style.boxShadow = '';
    }
  }

  // Initial check (handles page load mid-scroll / back-navigation)
  applyState(window.scrollY > 40);

  window.addEventListener('scroll', () => applyState(window.scrollY > 40), { passive: true });

  // ── Mobile menu toggle ────────────────────────────────────────────────────
  const toggle   = document.getElementById('nav-toggle');
  const menu     = document.getElementById('mobile-nav');
  const iconOpen  = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>

