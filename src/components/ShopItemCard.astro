---
interface Props {
  title: string;
  description: string;
  price?: string;
  badge?: string;
  image: string;
  externalUrl: string;
  viewLabel: string;
}

const { title, description, price, badge, image, externalUrl, viewLabel } = Astro.props;
---

<article class="bg-parchment rounded-xl border border-warm-border overflow-hidden hover:shadow-md transition-shadow group flex flex-col">
  <!-- Image area -->
  <div class="aspect-square bg-gradient-to-br from-parchment via-warm-border/30 to-cream flex items-center justify-center overflow-hidden">
    <img
      src={image}
      alt={title}
      width="400"
      height="400"
      class="w-full h-full object-cover opacity-0 group-hover:opacity-100 transition-opacity"
      onerror="this.style.display='none'"
      loading="lazy"
    />
    <!-- Placeholder shown when image is absent -->
    <span class="absolute text-5xl opacity-15 group-hover:opacity-25 transition-opacity select-none" aria-hidden="true">☕</span>
  </div>

  <div class="p-5 flex flex-col flex-1">
    <!-- Name + badge -->
    <div class="flex items-start justify-between gap-2 mb-2">
      <h3 class="font-serif text-espresso font-semibold text-base leading-snug">{title}</h3>
      {badge && (
        <span class="shrink-0 text-xs bg-caramel/10 text-caramel px-2 py-0.5 rounded-full font-medium whitespace-nowrap">
          {badge}
        </span>
      )}
    </div>

    <p class="text-sm text-sand leading-relaxed flex-1 mb-4">{description}</p>

    <div class="flex items-center justify-between gap-3">
      {price && <p class="font-semibold text-espresso">{price}</p>}
      <a
        href={externalUrl}
        class="text-xs font-medium text-caramel hover:text-caramel/70 transition-colors border border-caramel/30 rounded px-3 py-1.5 hover:border-caramel/60 ml-auto"
      >
        {viewLabel}
      </a>
    </div>
  </div>
</article>
