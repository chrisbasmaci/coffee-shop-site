---
import type { ShopItem } from '../data/shopItems';

interface Props {
  item: ShopItem;
  lang: 'tr' | 'en';
}

const { item, lang } = Astro.props;
const title       = item.title[lang];
const description = item.description[lang];
const details     = item.details[lang];
const badge       = item.badge?.[lang];
const usesExternalImage = item.image.startsWith('http');
const isComingSoon = item.externalUrl === '#';
const btnLabel = isComingSoon
  ? (lang === 'tr' ? 'Yakında' : 'Coming Soon')
  : (lang === 'tr' ? 'Ürünü İncele' : 'View Item');
---

<article class="bg-parchment rounded-xl border border-warm-border overflow-hidden hover:shadow-md transition-shadow group flex flex-col">
  <!-- Image area -->
  <div class="relative aspect-square bg-gradient-to-br from-parchment via-warm-border/30 to-cream flex items-center justify-center overflow-hidden">
    {badge && (
      <span class="absolute top-3 left-3 z-10 text-xs font-medium bg-caramel text-cream px-2.5 py-1 rounded-full">
        {badge}
      </span>
    )}
    <img
      src={item.image}
      alt={title}
      width="400"
      height="400"
      class={`w-full h-full ${usesExternalImage ? 'object-contain p-4' : 'object-cover'}`}
      onerror="this.style.display='none'"
      loading="lazy"
    />
  </div>

  <div class="p-5 flex flex-col flex-1">
    <h3 class="font-serif text-espresso font-semibold text-base leading-snug mb-1">{title}</h3>
    <p class="text-sm text-sand leading-relaxed mb-3 flex-1">{description}</p>

    {details.length > 0 && (
      <ul class="flex flex-wrap gap-1.5 mb-3">
        {details.map(d => (
          <li class="text-xs bg-cream border border-warm-border text-sand px-2 py-0.5 rounded-full">{d}</li>
        ))}
      </ul>
    )}

    <div class="flex items-center justify-between gap-3 mt-auto">
      <p class="font-semibold text-espresso">{item.price}</p>
      <a
        href={item.externalUrl}
        class={`text-xs font-medium rounded px-3 py-1.5 border transition-colors ${
          isComingSoon
            ? 'border-warm-border text-sand cursor-default pointer-events-none'
            : 'border-caramel/30 text-caramel hover:border-caramel/60 hover:text-caramel/70'
        }`}
        {...(isComingSoon ? {} : { target: '_blank', rel: 'noopener' })}
      >
        {btnLabel}
      </a>
    </div>
  </div>
</article>
