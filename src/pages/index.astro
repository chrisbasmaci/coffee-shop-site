---
import '../styles/global.css';
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content="CiniliCafe — İstanbul" />
    <title>CiniliCafe</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500&family=Playfair+Display:ital,wght@0,600;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-cream flex items-center justify-center px-4 antialiased">
    <div class="text-center max-w-sm w-full">

      <!-- Logo / Brand -->
      <div class="mb-2" aria-hidden="true">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full border border-warm-border mb-6">
          <span class="font-serif text-2xl text-caramel/60">ç</span>
        </div>
      </div>

      <h1 class="font-serif text-3xl sm:text-4xl font-semibold text-espresso mb-2 tracking-wide">
        CiniliCafe
      </h1>
      <p class="text-sm text-sand mb-10">İstanbul</p>

      <!-- Language choice -->
      <div class="flex flex-col gap-3">
        <a
          href="/tr/"
          class="block w-full bg-espresso text-cream text-sm font-medium py-3.5 rounded-md hover:bg-espresso/90 transition-colors"
          hreflang="tr"
        >
          Türkçe
        </a>
        <a
          href="/en/"
          class="block w-full border border-espresso/30 text-espresso text-sm font-medium py-3.5 rounded-md hover:bg-espresso/5 transition-colors"
          hreflang="en"
        >
          English
        </a>
      </div>
    </div>
  </body>
</html>

