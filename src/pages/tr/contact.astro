---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactCard from '../../components/ContactCard.astro';
import { t } from '../../i18n/translations';
import { siteInfo } from '../../data/siteInfo';

const tr = t.tr;
const page = tr.contact;
---

<BaseLayout title={page.meta.title} description={page.meta.description} lang="tr" currentPage="contact">

  <!-- Page header -->
  <div class="bg-parchment border-b border-warm-border py-16 sm:py-20 px-4">
    <div class="max-w-2xl mx-auto text-center">
      <h1 class="font-serif text-4xl sm:text-5xl text-espresso font-semibold mb-4">
        {page.heading}
      </h1>
      <p class="text-sand text-base sm:text-lg leading-relaxed">{page.intro}</p>
    </div>
  </div>

  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12 lg:gap-20">

      <!-- Details -->
      <div class="flex flex-col gap-8">
        <ContactCard
          label={page.labels.address}
          value={siteInfo.address.tr}
        />
        <ContactCard
          label={page.labels.email}
          value={siteInfo.email}
          href={`mailto:${siteInfo.email}`}
          multiline
        />

        <!-- Hours -->
        <div>
          <p class="text-xs font-medium tracking-[0.2em] uppercase text-caramel mb-3">
            {page.labels.hours}
          </p>
          <ul class="text-sm space-y-2">
            {siteInfo.openingHours.tr.map(row => (
              <li class="text-ink">{row}</li>
            ))}
          </ul>
        </div>

        <!-- Social -->
        <div>
          <p class="text-xs font-medium tracking-[0.2em] uppercase text-caramel mb-3">
            {page.labels.instagram}
          </p>
          <a
            href={siteInfo.instagram}
            target="_blank"
            rel="noopener"
            class="text-sm font-medium text-ink hover:text-caramel transition-colors"
          >
            @cinilikafe
          </a>
        </div>
      </div>

      <!-- Map -->
      <div class="flex flex-col gap-4">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d3010.4!2d28.9688147!3d41.0109701!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14cab993e122c615%3A0x97b28ae77ec9b230!2sCinili+Cafe!5e0!3m2!1str!2str!4v1748134000000!5m2!1str!2str"
          class="w-full aspect-video rounded-xl border border-warm-border"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Cinili Cafe haritası"
          allowfullscreen
        ></iframe>

        <a
          href={siteInfo.mapsUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 text-sm font-medium text-caramel hover:text-caramel/70 transition-colors self-start"
        >
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          {page.mapCta}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
